# ──────────────────────────────────────────────────────────────────────────
# RupiyaMaker CRM — backend-dev environment variables
#
# Copy this file to `.env` (same directory) and fill in real values.
# Backend reads it automatically via app/config.py -> load_dotenv().
# ──────────────────────────────────────────────────────────────────────────

# ── Server / DB (already used by config.py; uncomment to override defaults)
# HOST=localhost
# PORT=8051
# MONGO_URI=mongodb://...
# COMPANY_NAME=crm_database
# SECRET_KEY=change-me
# ENVIRONMENT=development

# ── Login OTP email (Gmail SMTP) ──────────────────────────────────────────
# Used by app/services/email_service.py to send OTPs to the personal_email
# of each employee configured as an OTP approver in
# Settings → OTP Verification.
#
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification on the Gmail account.
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Generate a 16-character app password (no spaces).
#   4. Paste it in SMTP_PASSWORD below.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USERNAME=your.notifier@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=RupiyaMaker CRM
