{
  "apps": [
    {
      "name": "rupiyame-backend",
      "script": "/www/wwwroot/RupiyaMe/backend/start_backend.sh",
      "args": "",
      "cwd": "/www/wwwroot/RupiyaMe/backend",
      "interpreter": "bash",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "1200M",
      "env": {
        "PYTHONPATH": "/www/wwwroot/RupiyaMe/backend",
        "ENVIRONMENT": "production",
        "PYTHONUNBUFFERED": "1"
      },
      "out_file": "/www/wwwroot/RupiyaMe/backend/logs/backend-out.log",
      "error_file": "/www/wwwroot/RupiyaMe/backend/logs/backend-error.log",
      "time": true,
      "restart_delay": 4000,
      "max_restarts": 1000,
      "min_uptime": "30s",
      "kill_timeout": 35000
    },
    {
      "name": "rupiyame-frontend",
      "script": "npm",
      "args": "run dev",
      "cwd": "/www/wwwroot/RupiyaMe/rupiyamaker-UI/crm",
      "interpreter": "none",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "development",
        "VITE_API_BASE_URL": "https://localhost:8049"
      },
      "log_file": "/www/wwwroot/RupiyaMe/logs/rupiyame-frontend.log",
      "out_file": "/www/wwwroot/RupiyaMe/logs/rupiyame-frontend-out.log",
      "error_file": "/www/wwwroot/RupiyaMe/logs/rupiyame-frontend-error.log",
      "time": true,
      "restart_delay": 3000,
      "max_restarts": 5,
      "min_uptime": "10s"
    }
  ]
}
