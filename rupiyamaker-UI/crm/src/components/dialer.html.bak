<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Team Performance Dashboard – 21 Feb 2026</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <style>
    :root {
      --bg: #000000;
      --surface: #000000;
      --surface2: #000000;
      --surface3: #0a0a0a;
      --border: #1a1a1a;
      --border2: #252525;
      --text: #ffffff;
      --text2: #ffffff;
      --muted: #cccccc;
      --accent: #4f7cff;
      --yellow: #00BCD4;
      --yellow-dim: #004d5a;
      --green: #1e7e34;
      --green-dim: #1e7e34;
      --green-border: #1e7e34;
      --red: #c0392b;
      --red-dim: #c0392b;
      --red-border: #c0392b;
      --neutral-border: #1e1e1e;
      --blue: #60a5fa;
      --purple: #a78bfa;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      overflow-x: auto;
    }

    body {
      background: #000000;
      color: #ffffff;
      font-family: "Segoe UI", system-ui, sans-serif;
      font-size: 13px;
      font-weight: 600;
      min-height: 100vh;
      min-width: 1240px;
    }

    /* TOPBAR */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: #000000;
      border-bottom: 2px solid #00BCD4;
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      box-shadow: 0 2px 20px rgba(0, 0, 0, .8);
    }

    .live-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #28A745;
      box-shadow: 0 0 0 3px rgba(40, 167, 69, .3);
      flex-shrink: 0;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        box-shadow: 0 0 0 3px rgba(40, 167, 69, .3);
      }

      50% {
        box-shadow: 0 0 0 6px rgba(40, 167, 69, .1);
      }
    }

    .topbar h1 {
      font-size: 15px;
      font-weight: 900;
      color: #ffffff;
      letter-spacing: .3px;
    }

    .topbar .sub {
      font-size: 12px;
      color: #ffffff;
      font-weight: 600;
    }

    .tags {
      margin-left: auto;
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .tag {
      background: #000000;
      border: 1px solid #00BCD4;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      color: #ffffff;
      font-weight: 700;
    }

    .tag b {
      color: #00BCD4;
      font-weight: 900;
    }

    /* KPI */
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 8px;
      padding: 12px 20px;
    }

    .kpi {
      background: #000000;
      border: 1px solid var(--border2);
      border-radius: 10px;
      padding: 12px 14px;
      position: relative;
      overflow: hidden;
      transition: border-color .2s;
    }

    .kpi:hover {
      border-color: var(--border2);
    }

    .kpi::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
    }

    .kpi.ck-b::before {
      background: var(--blue);
    }

    .kpi.ck-g::before {
      background: var(--green);
    }

    .kpi.ck-p::before {
      background: var(--purple);
    }

    .kpi.ck-y::before {
      background: var(--yellow);
    }

    .kpi.ck-r::before {
      background: var(--red);
    }

    .kpi.ck-o::before {
      background: #fb923c;
    }

    .kpi .klbl {
      font-size: 9px;
      font-weight: 800;
      color: #00BCD4;
      text-transform: uppercase;
      letter-spacing: .8px;
      margin-bottom: 4px;
    }

    .kpi .kval {
      font-size: 22px;
      font-weight: 900;
      color: #ffffff;
      line-height: 1;
    }

    .kpi .ksub {
      font-size: 10px;
      color: #ffffff;
      font-weight: 600;
      margin-top: 2px;
    }

    /* TOOLBAR - HIDDEN */
    .toolbar {
      display: none;
    }

    /* TABLE WRAPPER */
    .tw {
      padding: 0 20px 32px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 1200px;
      background: #000000;
    }

    /* RULES MODAL */
    .rules-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(4px);
      align-items: flex-start;
      justify-content: center;
      overflow-y: auto;
      padding: 40px 20px;
    }

    .rules-modal-overlay.show {
      display: flex;
    }

    .rules-modal {
      background: #0d0d0d;
      border: 1.5px solid #00BCD4;
      border-radius: 12px;
      width: 100%;
      max-width: 980px;
      box-shadow: 0 0 60px rgba(0, 188, 212, 0.15);
      animation: modalIn .2s ease;
    }

    @keyframes modalIn {
      from {
        opacity: 0;
        transform: translateY(-18px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .rules-modal-header {
      padding: 18px 24px;
      background: #003d4d;
      border-radius: 12px 12px 0 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1.5px solid #00BCD4;
    }

    .rules-modal-header h2 {
      font-size: 16px;
      font-weight: 900;
      color: #00BCD4;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: .8px;
    }

    .rules-close-btn {
      background: none;
      border: 2px solid #00BCD4;
      color: #00BCD4;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      font-size: 18px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      line-height: 1;
      transition: all .15s;
    }

    .rules-close-btn:hover {
      background: #00BCD4;
      color: #000;
    }

    .rules-modal-body {
      padding: 20px 24px 28px;
    }

    .rules-section-hdr {
      font-size: 11px;
      font-weight: 900;
      color: #00BCD4;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin: 18px 0 10px;
      padding-bottom: 6px;
      border-bottom: 1px solid #1a3a40;
    }

    .rules-section-hdr:first-child {
      margin-top: 0;
    }

    .rule-card {
      background: #111;
      border: 1px solid #1a1a1a;
      border-left: 3px solid #00BCD4;
      border-radius: 6px;
      padding: 12px 14px;
      margin-bottom: 8px;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 12px;
      align-items: start;
    }

    .rule-card.rule-critical {
      border-left-color: #c0392b;
    }

    .rule-card.rule-warn {
      border-left-color: #f59e0b;
    }

    .rule-card.rule-info {
      border-left-color: #60a5fa;
    }

    .rule-card-title {
      font-size: 12px;
      font-weight: 900;
      color: #ffffff;
      text-transform: uppercase;
      letter-spacing: .3px;
      line-height: 1.4;
    }

    .rule-card-badge {
      display: inline-block;
      font-size: 9px;
      font-weight: 900;
      padding: 2px 7px;
      border-radius: 20px;
      margin-top: 4px;
      text-transform: uppercase;
    }

    .badge-red {
      background: #c0392b;
      color: #fff;
    }

    .badge-orange {
      background: #f59e0b;
      color: #000;
    }

    .badge-blue {
      background: #60a5fa;
      color: #000;
    }

    .rule-card-desc {
      font-size: 11.5px;
      color: #cccccc;
      line-height: 1.6;
      font-weight: 600;
    }

    .rule-card-desc strong {
      color: #ffffff;
    }

    .rule-card-desc .eg {
      color: #888;
      font-size: 11px;
      margin-top: 4px;
      display: block;
    }

    /* Rules open button in ctrl-bar */
    .rules-open-btn {
      padding: 6px 14px;
      background: #003d4d;
      border: 2px solid #00BCD4;
      color: #00BCD4;
      font-size: 11px;
      font-weight: 900;
      border-radius: 6px;
      cursor: pointer;
      transition: all .2s;
      font-family: 'Arial Black', Arial, sans-serif;
      white-space: nowrap;
    }

    .rules-open-btn:hover {
      background: #00BCD4;
      color: #000;
    }

    /* STICKY HEADER — works because body is the scroll container */
    thead {
      position: sticky;
      top: 44px;
      z-index: 50;
    }

    thead tr {
      background: #ffffff !important;
    }

    thead th {
      padding: 10px 12px;
      background: #ffffff;
      border-bottom: 2px solid #00BCD4;
      border-right: 1px solid #e0e0e0;
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: .8px;
      color: #00BCD4;
      cursor: pointer;
      white-space: nowrap;
      user-select: none;
      text-align: left;
      transition: all .15s;
    }

    thead th:last-child {
      border-right: none;
    }

    thead th:hover {
      background: #f0f8ff;
      color: #0097a7;
    }

    /* ROWS */
    tbody tr {
      border-bottom: 2px solid #1a1a1a;
    }

    tbody tr:last-child {
      border-bottom: none;
    }

    tbody tr:hover td {
      background: #0a0a0a;
    }

    td {
      padding: 8px 10px;
      border-right: 1px solid var(--border);
      vertical-align: top;
      background: transparent;
    }

    td:last-child {
      border-right: none;
    }

    /* RANK */
    .rnk {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 900;
    }

    .r1 {
      background: linear-gradient(135deg, #fbbf24, #f59e0b);
      color: #000000;
    }

    .r2 {
      background: linear-gradient(135deg, #94a3b8, #64748b);
      color: #ffffff;
    }

    .r3 {
      background: linear-gradient(135deg, #f97316, #ea580c);
      color: #ffffff;
    }

    .rn {
      background: #0a0a0a;
      color: #ffffff;
    }

    /* AGENT */
    .ag-name {
      font-weight: 900;
      font-size: 16px;
      color: #ffffff;
      letter-spacing: .2px;
    }

    .ag-ext {
      font-size: 12px;
      color: #aaaaaa;
      font-weight: 700;
      margin-top: 3px;
    }

    /*  CELL BOX  */
    .cbox {
      border-radius: 6px;
      padding: 7px 9px;
      border: 1.5px solid;
      display: block;
      font-weight: 700;
    }

    .cbox-green {
      background: #1e7e34;
      border-color: #1e7e34;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .cbox-red {
      background: #c0392b;
      border-color: #c0392b;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .cbox-neutral {
      background: #0a0a0a;
      border-color: var(--border2);
    }

    /* Text inside cbox */
    .cbox-green *,
    .cbox-green {
      color: #ffffff !important;
      font-weight: 800;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .cbox-red,
    .cbox-red * {
      color: #ffffff !important;
      font-weight: 800;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .cbox-neutral *,
    .cbox-neutral {
      color: #ffffff !important;
      font-weight: 600;
    }

    /* LOGIN DURATION */
    .ld-dur {
      font-size: 15px;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .ld-times {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-top: 6px;
    }

    .ld-row {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 700;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .ld-arrow {
      opacity: .5;
    }

    .time-tag {
      font-size: 10px;
      font-weight: 900;
      padding: 2px 6px;
      border-radius: 4px;
      min-width: 30px;
      text-align: center;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .in-tag {
      background: #2196f3;
      color: #ffffff;
      border: 1px solid #2196f3;
    }

    .out-tag {
      background: #f44336;
      color: #ffffff;
      border: 1px solid #f44336;
    }

    /* CALLS */
    .calls-big {
      font-size: 18px;
      font-weight: 900;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .calls-sub {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-top: 6px;
    }

    .csplit {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 700;
    }

    .ob-tag {
      background: #2a4a75;
      color: #70b3ff;
      font-size: 11px;
      font-weight: 900;
      padding: 2px 7px;
      border-radius: 4px;
      border: 1px solid #60a5fa;
      min-width: 30px;
      text-align: center;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .mn-tag {
      background: #9c27b0;
      color: #ffffff;
      font-size: 11px;
      font-weight: 900;
      padding: 2px 7px;
      border-radius: 4px;
      border: 1px solid #9c27b0;
      min-width: 30px;
      text-align: center;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .calls-sub .num {
      font-weight: 800;
      font-size: 13px;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    /* TALK TIME */
    .tt-big {
      font-size: 15px;
      font-weight: 900;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .tt-sub {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-top: 6px;
    }

    .tt-sub .csplit {
      font-size: 12px;
    }

    .tt-sub .num {
      font-size: 13px;
      color: #ffffff;
      font-weight: 800;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .tt-note {
      font-size: 11px;
      font-weight: 700;
      margin-top: 3px;
      opacity: 1;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    /* WRAPUP */
    .wu-row1 {
      font-size: 14px;
      font-weight: 900;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
      line-height: 1.4;
    }

    .wu-sep {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.45);
      margin: 0 2px;
    }

    .wu-row2 {
      font-size: 11px;
      margin-top: 5px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.65);
      font-family: 'Arial Black', Arial, sans-serif;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
      padding-top: 4px;
    }

    .wu-extra {
      font-size: 12px;
      margin-top: 4px;
      font-weight: 900;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
      background: rgba(0, 0, 0, 0.28);
      border-radius: 4px;
      padding: 2px 7px;
      display: inline-block;
    }

    /* SERIAL NUMBER */
    .sn-num {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 900;
      background: #111111;
      color: #aaaaaa;
      border: 1px solid #333333;
    }

    /* IDLE */
    .idle-main {
      font-size: 14px;
      font-weight: 800;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    /* BREAK */
    .brk-main {
      font-size: 14px;
      font-weight: 800;
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .brk-sub {
      font-size: 11px;
      margin-top: 2px;
      font-weight: 700;
      color: #ffffff;
      opacity: 1;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    /* ISSUES & WASTE */
    .iw-zero {
      font-size: 14px;
      font-weight: 900;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .iw-head {
      font-size: 15px;
      font-weight: 900;
      margin-bottom: 8px;
      font-family: 'Arial Black', Arial, sans-serif;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }

    .iw-head-txt {
      flex: 1;
      line-height: 1.3;
    }

    .iw-items {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .iw-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
    }

    .iw-label {
      font-size: 13px;
      font-weight: 800;
      line-height: 1.4;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .iw-val {
      font-size: 17px;
      font-weight: 900;
      text-align: right;
      white-space: nowrap;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    /* WhatsApp small icon button */
    .wa-btn {
      background: #25d366;
      border: none;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      font-size: 15px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all .15s;
    }

    .wa-btn:hover {
      background: #1aa756;
      transform: scale(1.15);
    }

    /* CONTROLS BAR */
    .ctrl-bar {
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      background: #000000;
      border-bottom: 1px solid #1a1a1a;
    }

    .ds-label {
      font-size: 12px;
      font-weight: 900;
      color: #00BCD4;
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    .dt-sel {
      padding: 6px 14px;
      background: #003d4d;
      border: 2px solid #00BCD4;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      border-radius: 6px;
      cursor: pointer;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .dt-sel:hover,
    .dt-sel:focus {
      background: #00576b;
      outline: none;
    }

    .vw-grp {
      display: flex;
      gap: 6px;
      margin-left: auto;
    }

    .vbtn {
      padding: 6px 18px;
      background: #000000;
      border: 2px solid #00BCD4;
      color: #00BCD4;
      font-size: 11px;
      font-weight: 900;
      border-radius: 6px;
      cursor: pointer;
      transition: all .2s;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .vbtn:hover {
      background: #003540;
    }

    .vbtn.active {
      background: #00BCD4;
      color: #000000;
    }

    /* scrollbar */
    ::-webkit-scrollbar {
      width: 5px;
      height: 5px;
    }

    ::-webkit-scrollbar-track {
      background: var(--bg);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border2);
      border-radius: 3px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #444;
    }

    /* UPLOAD BUTTON */
    .upload-btn {
      padding: 6px 16px;
      background: #003d4d;
      border: 2px solid #00BCD4;
      color: #00BCD4;
      font-size: 11px;
      font-weight: 900;
      border-radius: 6px;
      cursor: pointer;
      transition: all .2s;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .upload-btn:hover {
      background: #00BCD4;
      color: #000;
    }

    .upload-btn.loaded {
      background: #1e3a1e;
      border-color: #28a745;
      color: #28a745;
    }

    .upload-btn.loaded:hover {
      background: #28a745;
      color: #000;
    }

    /* UPLOAD MODAL */
    .upl-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 2000;
      background: rgba(0, 0, 0, .88);
      backdrop-filter: blur(4px);
      align-items: center;
      justify-content: center;
      padding: 30px 20px;
    }

    .upl-overlay.show {
      display: flex;
    }

    .upl-modal {
      background: #0d0d0d;
      border: 2px solid #00BCD4;
      border-radius: 12px;
      width: 100%;
      max-width: 520px;
      box-shadow: 0 0 60px rgba(0, 188, 212, .2);
      animation: modalIn .2s ease;
    }

    .upl-header {
      padding: 16px 22px;
      background: #003d4d;
      border-radius: 12px 12px 0 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 2px solid #00BCD4;
    }

    .upl-header h2 {
      font-size: 14px;
      font-weight: 900;
      color: #00BCD4;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: .8px;
    }

    .upl-close {
      background: none;
      border: 2px solid #00BCD4;
      color: #00BCD4;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      transition: all .15s;
    }

    .upl-close:hover {
      background: #00BCD4;
      color: #000;
    }

    .upl-body {
      padding: 20px 22px;
    }

    .dropzone {
      border: 2px dashed #00BCD4;
      border-radius: 8px;
      padding: 30px 20px;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      background: #001a1f;
      margin-bottom: 14px;
    }

    .dropzone:hover,
    .dropzone.drag {
      border-color: #fff;
      background: #002a33;
    }

    .dropzone .dz-icon {
      font-size: 32px;
      margin-bottom: 8px;
    }

    .dropzone .dz-title {
      font-size: 13px;
      font-weight: 900;
      color: #00BCD4;
      margin-bottom: 4px;
    }

    .dropzone .dz-sub {
      font-size: 10px;
      color: #888;
      font-weight: 700;
    }

    .upl-status {
      border-radius: 8px;
      padding: 14px 16px;
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 10px;
      line-height: 1.5;
    }

    .upl-status.parsing {
      background: #001a1f;
      color: #00BCD4;
      border: 1px solid #00BCD4;
    }

    .upl-status.success {
      background: #0a1f0a;
      color: #28a745;
      border: 1px solid #28a745;
    }

    .upl-status.error {
      background: #1a0505;
      color: #e74c3c;
      border: 1px solid #e74c3c;
      white-space: pre-wrap;
    }

    .upl-action-row {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
      margin-top: 14px;
    }

    .upl-btn {
      padding: 7px 18px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 900;
      cursor: pointer;
      border: 2px solid;
      transition: all .15s;
      font-family: 'Arial Black', Arial, sans-serif;
    }

    .upl-btn-confirm {
      background: #003d4d;
      border-color: #00BCD4;
      color: #00BCD4;
    }

    .upl-btn-confirm:hover {
      background: #00BCD4;
      color: #000;
    }

    .upl-btn-cancel {
      background: #1a0505;
      border-color: #c0392b;
      color: #c0392b;
    }

    .upl-btn-cancel:hover {
      background: #c0392b;
      color: #fff;
    }

    .upl-btn-clear {
      background: #1a1000;
      border-color: #f59e0b;
      color: #f59e0b;
    }

    .upl-btn-clear:hover {
      background: #f59e0b;
      color: #000;
    }
  </style>
</head>

<body>

  <div class="topbar">
    <div class="live-dot"></div>
    <h1>Team Performance Dashboard</h1>
    <span class="sub">&nbsp;&nbsp; CRMPRO Campaign &nbsp;&nbsp; <span id="topDate">—</span></span>
    <div class="tags">
      <div class="tag">Shift <b>10:30 AM – 7:00 PM</b></div>
      <div class="tag">Agents <b id="agentCount">—</b></div>
      <div class="tag">Break Limit <b>1h</b></div>
      <div class="tag">Manual Idle <b>Zero Tolerance</b></div>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi ck-b">
      <div class="klbl">Total Calls</div>
      <div class="kval" id="k1">—</div>
      <div class="ksub">Team total</div>
    </div>
    <div class="kpi ck-g">
      <div class="klbl">Total Talk Time</div>
      <div class="kval" id="k2">—</div>
      <div class="ksub">hrs across team</div>
    </div>
    <div class="kpi ck-p">
      <div class="klbl">Avg Login Duration</div>
      <div class="kval" id="k3">—</div>
      <div class="ksub">Target 8:30 hrs</div>
    </div>
    <div class="kpi ck-y">
      <div class="klbl">Late Logins</div>
      <div class="kval" id="k4">—</div>
      <div class="ksub">After 10:30 AM</div>
    </div>
    <div class="kpi ck-r">
      <div class="klbl">Manual Idle Issues</div>
      <div class="kval" id="k5">—</div>
      <div class="ksub">any idle agents</div>
    </div>
    <div class="kpi ck-o">
      <div class="klbl">Total Team Waste</div>
      <div class="kval" id="k6">—</div>
      <div class="ksub">hrs wasted today</div>
    </div>
  </div>

  <!-- CONTROLS BAR -->
  <div class="ctrl-bar">
    <button class="rules-open-btn" onclick="toggleRules()">📋 Performance Rules</button>
    <button class="upload-btn" id="uploadBtn" onclick="openUpload()">📊 Upload Excel</button>
    <input type="file" id="excelFileInput" accept=".xlsx,.xls" style="display:none" onchange="handleFileInput(this)" />
    <span class="ds-label">� Agent:</span>
    <select class="dt-sel" id="agentSelect" onchange="applyFilters()">
      <option value="">All Agents</option>
    </select>
    <span class="ds-label">📅 From:</span>
    <select class="dt-sel" id="dateFrom" onchange="applyFilters()"></select>
    <span class="ds-label">To:</span>
    <select class="dt-sel" id="dateTo" onchange="applyFilters()"></select>
  </div>

  <!-- UPLOAD MODAL -->
  <div class="upl-overlay" id="uplModal" onclick="closeUplOutside(event)">
    <div class="upl-modal">
      <div class="upl-header">
        <h2>📊 Upload Excel Data</h2>
        <button class="upl-close" onclick="closeUpload()">✕</button>
      </div>
      <div class="upl-body">
        <div class="dropzone" id="dropzone" onclick="document.getElementById('excelFileInput').click()"
          ondragover="dzOver(event)" ondragleave="dzLeave(event)" ondrop="dzDrop(event)">
          <div class="dz-icon">📂</div>
          <div class="dz-title">Click or drag &amp; drop Excel file here</div>
          <div class="dz-sub">.xlsx / .xls · Max 10MB</div>
        </div>
        <div class="upl-status parsing" id="uplStatus" style="display:none"></div>
        <div class="upl-action-row" id="uplActions" style="display:none"></div>
      </div>
    </div>
  </div>

  <!-- RULES MODAL -->
  <div class="rules-modal-overlay" id="rulesModal" onclick="closeModalOutside(event)">
    <div class="rules-modal">
      <div class="rules-modal-header">
        <h2>📋 Performance Rules &amp; Thresholds</h2>
        <button class="rules-close-btn" onclick="toggleRules()">✕</button>
      </div>
      <div class="rules-modal-body">

        <div class="rules-section-hdr">🕐 1. Login / Logout Rule</div>
        <div class="rule-card rule-critical">
          <div>
            <div class="rule-card-title">Login Timing</div>
            <span class="rule-card-badge badge-red">🔴 Critical</span>
          </div>
          <div class="rule-card-desc">
            Agent must log in <strong>before 10:30 AM</strong> and log out at or after <strong>7:00 PM</strong>.<br>
            If either condition fails, the <strong>Login Duration cell turns RED</strong> and waste time is added.<br>
            <span class="eg">Example: Login at 10:45 AM → +15 min late waste. Exit at 6:45 PM → +15 min early
              waste.</span>
          </div>
        </div>

        <div class="rules-section-hdr">📞 2. Calls (OB + MN)</div>
        <div class="rule-card rule-info">
          <div>
            <div class="rule-card-title">Call Count</div>
            <span class="rule-card-badge badge-blue">ℹ Info Only</span>
          </div>
          <div class="rule-card-desc">
            Calls column shows <strong>Outbound (OB) + Manual (MN)</strong> combined count.<br>
            <strong>No red/green threshold</strong> is applied on call count — it is for reference only.
          </div>
        </div>

        <div class="rules-section-hdr">⏱️ 3. Talk Time Rule</div>
        <div class="rule-card rule-critical">
          <div>
            <div class="rule-card-title">Suspicious Talk Time</div>
            <span class="rule-card-badge badge-red">🔴 Critical</span>
          </div>
          <div class="rule-card-desc">
            Marked <strong>⚠ Suspicious Talk Time</strong> (red) if:<br>
            <strong>Manual Talk Time ≥ 40% of Outbound Talk Time</strong>.<br>
            This indicates the agent may be spending too much time on manual/inbound calls relative to outbound
            activity.
            <span class="eg">Example: OB TT = 2h, MN TT ≥ 48m → RED ⚠ Suspicious Talk Time</span>
          </div>
        </div>

        <div class="rules-section-hdr">📝 4. Wrap-up Time Rule</div>
        <div class="rule-card rule-critical">
          <div>
            <div class="rule-card-title">Wrapup Per Call</div>
            <span class="rule-card-badge badge-red">🔴 Critical</span>
          </div>
          <div class="rule-card-desc">
            Average wrap-up time must be <strong>≤ 10 seconds per call</strong>.<br>
            If average exceeds 10s/call, the Wrapup cell turns <strong>RED</strong> and excess time goes to waste.
            <span class="eg">Example: 20 calls, max allowed wrapup = 200s (3m 20s). Anything above = waste.</span>
          </div>
        </div>

        <div class="rules-section-hdr">⏸️ 5. Auto Idle</div>
        <div class="rule-card rule-info">
          <div>
            <div class="rule-card-title">System Idle</div>
            <span class="rule-card-badge badge-blue">ℹ Info Only</span>
          </div>
          <div class="rule-card-desc">
            Auto Idle is <strong>system-generated</strong> and shown for reference only.<br>
            No performance threshold is applied. Does not affect waste time calculation.
          </div>
        </div>

        <div class="rules-section-hdr">🚫 6. Manual Idle Rule</div>
        <div class="rule-card rule-critical">
          <div>
            <div class="rule-card-title">Manual Idle Limit</div>
            <span class="rule-card-badge badge-red">🔴 Critical</span>
          </div>
          <div class="rule-card-desc">
            <strong>Zero tolerance</strong> — any manual idle at all is a violation.<br>
            The entire manual idle duration is added directly to waste time. Cell turns <strong>RED</strong> for any
            non-zero amount.
            <span class="eg">Example: 3 min manual idle → cell = RED, 3 min added to waste. No free threshold.</span>
          </div>
        </div>

        <div class="rules-section-hdr">☕ 7. Break Time Rule</div>
        <div class="rule-card rule-critical">
          <div>
            <div class="rule-card-title">Break Limit</div>
            <span class="rule-card-badge badge-red">🔴 Critical</span>
          </div>
          <div class="rule-card-desc">
            Break cell turns <strong>RED</strong> if total break time exceeds <strong>1 hour</strong>.<br>
            Any break over <strong>1 hour</strong> counts fully as wasted time — no 15-minute buffer.
            <span class="eg">Example: Break = 1h 30m → 30 min wasted. Break = 1h 5m → 5 min wasted. Cell = RED.</span>
          </div>
        </div>

        <div class="rules-section-hdr">⚠️ Waste Time Summary</div>
        <div class="rule-card rule-warn">
          <div>
            <div class="rule-card-title">Total Waste</div>
            <span class="rule-card-badge badge-orange">⚠ Summary</span>
          </div>
          <div class="rule-card-desc">
            Waste cell shows <strong>issue count + total waste time</strong>. Issues aggregated:<br>
            🔴 Late Login &nbsp;|&nbsp; 🔴 Early Exit &nbsp;|&nbsp; 🚫 Manual Idle (any amount) &nbsp;|&nbsp; 📝 Wrapup
            &gt; 10s/call &nbsp;|&nbsp; ☕ Break &gt; 1h &nbsp;|&nbsp; ⚠ Suspicious Talk Time
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="tw">
    <table>
      <thead>
        <tr>
          <th style="width:32px">#</th>
          <th onclick="sortBy('name')">Agent</th>
          <th onclick="sortBy('loginDur')">Login Duration</th>
          <th onclick="sortBy('totalCalls')">Calls</th>
          <th onclick="sortBy('totalTT')">Talk Time</th>
          <th onclick="sortBy('wrapup')">Wrapup</th>
          <th onclick="sortBy('autoIdle')">Auto Idle</th>
          <th onclick="sortBy('manualIdle')">Manual Idle</th>
          <th onclick="sortBy('breakTime')">Break</th>
          <th style="min-width:240px" onclick="sortBy('wasteSec')">Waste Time</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>

  <script>
