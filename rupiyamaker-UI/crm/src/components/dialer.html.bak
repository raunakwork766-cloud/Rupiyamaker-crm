      { date: "2026-02-16", name: "Nishu", ext: "0227", loginTime: "10:32 AM", logoutTime: "06:53 PM", loginDur: "07:01:37", outCalls: 235, outTT: "00:38:01", manCalls: 0, manTT: "00:00:00", totalTT: "00:38:01", autoIdle: "01:26:30", manualIdle: "00:21:11", breakTime: "03:38:18", wrapup: "00:57:44", loginMin: 632, logoutMin: 1133 },
      { date: "2026-02-17", name: "Nishu", ext: "0227", loginTime: "10:35 AM", logoutTime: "06:59 PM", loginDur: "04:26:24", outCalls: 106, outTT: "00:30:43", manCalls: 0, manTT: "00:00:00", totalTT: "00:30:43", autoIdle: "00:43:42", manualIdle: "00:16:27", breakTime: "02:12:55", wrapup: "00:42:38", loginMin: 635, logoutMin: 1139 },
      { date: "2026-02-19", name: "Nishu", ext: "0227", loginTime: "10:33 AM", logoutTime: "05:03 PM", loginDur: "04:26:28", outCalls: 57, outTT: "00:26:15", manCalls: 2, manTT: "00:04:02", totalTT: "00:30:17", autoIdle: "00:24:14", manualIdle: "00:19:39", breakTime: "03:00:16", wrapup: "00:12:02", loginMin: 633, logoutMin: 1083 },
      { date: "2026-02-20", name: "Nishu", ext: "0227", loginTime: "02:10 PM", logoutTime: "06:43 PM", loginDur: "02:42:14", outCalls: 40, outTT: "00:17:12", manCalls: 0, manTT: "00:00:00", totalTT: "00:17:12", autoIdle: "00:19:08", manualIdle: "00:00:00", breakTime: "01:36:11", wrapup: "00:29:45", loginMin: 850, logoutMin: 1123 },
      // harshul — 4 days
      { date: "2026-02-17", name: "harshul", ext: "0347", loginTime: "11:06 AM", logoutTime: "05:05 PM", loginDur: "05:49:44", outCalls: 82, outTT: "00:34:14", manCalls: 0, manTT: "00:00:00", totalTT: "00:34:14", autoIdle: "00:44:53", manualIdle: "01:40:02", breakTime: "02:10:56", wrapup: "00:39:39", loginMin: 666, logoutMin: 1065 },
      { date: "2026-02-18", name: "harshul", ext: "0347", loginTime: "11:13 AM", logoutTime: "06:00 PM", loginDur: "05:03:47", outCalls: 61, outTT: "00:26:38", manCalls: 1, manTT: "00:00:03", totalTT: "00:26:41", autoIdle: "00:36:47", manualIdle: "02:17:11", breakTime: "01:32:48", wrapup: "00:10:20", loginMin: 673, logoutMin: 1120 },
      { date: "2026-02-19", name: "harshul", ext: "0347", loginTime: "03:10 PM", logoutTime: "06:03 PM", loginDur: "02:52:47", outCalls: 43, outTT: "00:13:59", manCalls: 0, manTT: "00:00:00", totalTT: "00:13:59", autoIdle: "00:17:24", manualIdle: "01:13:32", breakTime: "00:43:58", wrapup: "00:23:58", loginMin: 910, logoutMin: 1083 },
      { date: "2026-02-20", name: "harshul", ext: "0347", loginTime: "11:17 AM", logoutTime: "06:40 PM", loginDur: "07:22:52", outCalls: 96, outTT: "00:42:30", manCalls: 0, manTT: "00:00:00", totalTT: "00:42:30", autoIdle: "00:48:46", manualIdle: "03:12:24", breakTime: "01:19:58", wrapup: "01:19:14", loginMin: 677, logoutMin: 1120 },
    ];

    const LATE_MIN = 630, EARLY_MIN = 1140, MAX_BRK_SEC = 60 * 60, MAX_WU_SEC = 10, SHIFT_SEC = 8.5 * 3600;
    let selectedAgent = '', filterFrom = '', filterTo = '', sortKey = 'totalCalls', sortDir = -1;
    // Permanent agent serial numbers based on first-appearance order in ALL_AGENTS
    const _agentSN = {};
    (() => { let n = 1; ALL_AGENTS.forEach(a => { if (_agentSN[a.ext] === undefined) _agentSN[a.ext] = n++; }); })();

    function toSec(t) { if (!t) return 0; const p = t.split(':'); return +p[0] * 3600 + +p[1] * 60 + +p[2]; }
    function hms(s) { s = Math.max(0, Math.round(s)); const h = Math.floor(s / 3600), m = Math.floor(s % 3600 / 60), sc = s % 60; return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(sc).padStart(2, '0')}`; }
    function hmShort(s) { s = Math.max(0, Math.round(s)); if (s < 60) return `${s}s`; const h = Math.floor(s / 3600), m = Math.floor(s % 3600 / 60); if (h > 0 && m > 0) return `${h}h ${m}m`; if (h > 0) return `${h}h`; return `${m}m`; }
    function fmtDate(d) { if (!d) return '—'; const [y, mo, dy] = d.split('-'); const mn = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']; return `${parseInt(dy)} ${mn[parseInt(mo) - 1]} ${y}`; }

    function initFilters() {
      console.log('[initFilters] Called - ALL_AGENTS length:', ALL_AGENTS.length);
      console.log('[initFilters] Sample agents:', ALL_AGENTS.slice(0, 3).map(a => ({ name: a.name, date: a.date })));
      const dates = [...new Set(ALL_AGENTS.map(a => a.date))].sort();
      console.log('[initFilters] Unique dates array (sorted):', dates);
      const latest = dates[dates.length - 1];
      console.log('[initFilters] Latest date selected for dropdown:', latest);
      filterFrom = latest; filterTo = latest;
      ['dateFrom', 'dateTo'].forEach(id => {
        const sel = document.getElementById(id);
        [...dates].reverse().forEach(d => {
          const o = document.createElement('option');
          o.value = d; o.textContent = fmtDate(d); sel.appendChild(o);
        });
        sel.value = latest;
      });
      const seen = new Set();
      const asel = document.getElementById('agentSelect');
      ALL_AGENTS.forEach(a => {
        if (!seen.has(a.ext)) {
          seen.add(a.ext);
          const o = document.createElement('option');
          o.value = a.ext; o.textContent = a.name; asel.appendChild(o);
        }
      });
      updateTopbar();
      render();
    }

    function applyFilters() {
      selectedAgent = document.getElementById('agentSelect').value;
      filterFrom = document.getElementById('dateFrom').value;
      filterTo = document.getElementById('dateTo').value;
      if (filterFrom > filterTo) {
        const t = filterFrom; filterFrom = filterTo; filterTo = t;
        document.getElementById('dateFrom').value = filterFrom;
        document.getElementById('dateTo').value = filterTo;
      }
      updateTopbar();
      render();
    }

    function updateTopbar() {
      const isMultiDate = filterFrom !== filterTo;
      document.getElementById('topDate').textContent = isMultiDate ? `${fmtDate(filterFrom)} – ${fmtDate(filterTo)}` : fmtDate(filterFrom);
      const visible = ALL_AGENTS.filter(a => a.date >= filterFrom && a.date <= filterTo && (!selectedAgent || a.ext === selectedAgent));
      document.getElementById('agentCount').textContent = selectedAgent ? '1 agent' : [...new Set(visible.map(a => a.ext))].length;
    }

    function proc(a) {
      const tc = a.outCalls + a.manCalls;
      const isLate = a.loginMin > LATE_MIN, isEarly = a.logoutMin < EARLY_MIN;
      const ldSec = toSec(a.loginDur), brkSec = toSec(a.breakTime), miSec = toSec(a.manualIdle);
      const wuSec = toSec(a.wrapup), outTTs = toSec(a.outTT), manTTs = toSec(a.manTT), ttSec = toSec(a.totalTT);
      const avgWu = tc > 0 ? Math.round(wuSec / tc) : 0;
      const miBad = miSec > 0, brkBad = brkSec > MAX_BRK_SEC, wuBad = avgWu > MAX_WU_SEC;
      const ttBad = outTTs > 0 && manTTs >= outTTs * 0.4;
      const sessOk = !isLate && !isEarly;
      const lateWaste = isLate ? (a.loginMin - LATE_MIN) * 60 : 0;
      const earlyWaste = isEarly ? (EARLY_MIN - a.logoutMin) * 60 : 0;
      const miWaste = miSec, wuWaste = Math.max(0, wuSec - MAX_WU_SEC * tc);
      const brkWaste = Math.max(0, brkSec - MAX_BRK_SEC);
      const wasteSec = lateWaste + earlyWaste + miWaste + wuWaste + brkWaste;
      const wastePct = Math.round(wasteSec / SHIFT_SEC * 100);
      const lateMins = a.loginMin - LATE_MIN, earlyMins = EARLY_MIN - a.logoutMin;
      return {
        ...a, tc, isLate, isEarly, ldSec, brkSec, miSec, wuSec, outTTs, manTTs, ttSec, avgWu,
        miBad, brkBad, wuBad, ttBad, sessOk, wasteSec, wastePct,
        lateWaste, earlyWaste, miWaste, wuWaste, brkWaste, lateMins, earlyMins
      };
    }

    // Global copy texts indexed by row for safe onclick
    const _cpTexts = [];

    function render() {
      _cpTexts.length = 0;
      const isMultiDate = filterFrom !== filterTo;
      const isSingleAgent = !!selectedAgent;

      // Filter records
      let raw = ALL_AGENTS.filter(a => a.date >= filterFrom && a.date <= filterTo && (!selectedAgent || a.ext === selectedAgent));

      // Pre-sort raw before proc()
      if (isSingleAgent) {
        raw.sort((a, b) => a.date.localeCompare(b.date));
      } else if (isMultiDate) {
        const _ao = [];
        ALL_AGENTS.forEach(a => { if (!_ao.includes(a.ext)) _ao.push(a.ext); });
        raw.sort((a, b) => { const ai = _ao.indexOf(a.ext), bi = _ao.indexOf(b.ext); return ai !== bi ? ai - bi : a.date.localeCompare(b.date); });
      }

      let pd = raw.map(a => proc(a));

      // Assign permanent serial numbers
      if (isSingleAgent) {
        pd.forEach((a, i) => { a._sn = i + 1; }); // day 1,2,3... for single agent
      } else {
        pd.forEach(a => { a._sn = _agentSN[a.ext]; }); // fixed agent number always
      }

      // Rank map (for rank badges)
      const rkMap = {};
      [...pd].sort((a, b) => b.outCalls - a.outCalls).forEach((a, i) => { rkMap[`${a.ext}_${a.date}`] = i + 1; });

      // KPI
      const totalCalls = pd.reduce((s, a) => s + a.tc, 0);
      const totalTTSec = pd.reduce((s, a) => s + a.ttSec, 0);
      const avgLdH = pd.length > 0 ? (pd.reduce((s, a) => s + a.ldSec, 0) / pd.length / 3600).toFixed(1) : '0.0';
      document.getElementById('k1').textContent = totalCalls.toLocaleString('en-IN');
      document.getElementById('k2').textContent = (totalTTSec / 3600).toFixed(1) + 'h';
      document.getElementById('k3').textContent = avgLdH + 'h';
      document.getElementById('k4').textContent = pd.filter(a => a.isLate || a.isEarly).length;
      document.getElementById('k5').textContent = pd.filter(a => a.miBad).length;
      document.getElementById('k6').textContent = (pd.reduce((s, a) => s + a.wasteSec, 0) / 3600).toFixed(1) + 'h';

      // Column sort (only in single-date all-agents or single-agent view; preserve grouping in multi-date)
      let list = [...pd];
      if (!isMultiDate || isSingleAgent) {
        const kfn = {
          rank: x => x.outCalls, name: x => x.name.toLowerCase(), loginDur: x => x.ldSec,
          totalCalls: x => x.tc, totalTT: x => x.ttSec, wrapup: x => x.avgWu,
          autoIdle: x => toSec(x.autoIdle), manualIdle: x => x.miSec,
          breakTime: x => x.brkSec, wasteSec: x => x.wasteSec
        };
        list.sort((a, b) => { const f = kfn[sortKey] || (() => 0); const av = f(a), bv = f(b); return av < bv ? -sortDir : av > bv ? sortDir : 0; });
      }

      const tbody = document.getElementById('tbody');
      tbody.innerHTML = '';

      list.forEach(a => {
        const r = rkMap[`${a.ext}_${a.date}`] || 99;
        const rc = r === 1 ? 'r1' : r === 2 ? 'r2' : r === 3 ? 'r3' : 'rn';
        // Agent cell ext line: show date context in multi-date or single-agent views
        const extLine = (isMultiDate && !isSingleAgent)
          ? `${a.ext}&nbsp;·&nbsp;<span style="color:#00BCD4;font-weight:900">${fmtDate(a.date)}</span>`
          : isSingleAgent
            ? `<span style="color:#00BCD4;font-weight:900">${fmtDate(a.date)}</span>`
            : a.ext;
        const nameExtra = `<div class="ag-ext">${extLine}</div>`;

        /* LOGIN */
        const sc = a.sessOk ? 'cbox-green' : 'cbox-red';
        const sessHTML = `<div class="cbox ${sc}">
      <div class="ld-dur">${a.loginDur}</div>
      <div class="ld-times">
        <div class="ld-row"><span class="in-tag time-tag">IN</span><span>${a.loginTime}</span></div>
        <div class="ld-row"><span class="out-tag time-tag">OUT</span><span>${a.logoutTime}</span></div>
      </div></div>`;

        /* CALLS */
        const callsHTML = `<div class="cbox cbox-green">
      <div class="calls-big">${a.tc}</div>
      <div class="calls-sub">
        <div class="csplit"><span class="ob-tag">OB</span><span class="num">${a.outCalls}</span></div>
        <div class="csplit"><span class="mn-tag">MN</span><span class="num">${a.manCalls}</span></div>
      </div></div>`;

        /* TALK TIME */
        const tc2 = a.ttBad ? 'cbox-red' : 'cbox-green';
        const ttNote = a.ttBad ? ' ⚠ Suspicious Talk Time' : '';
        const ttHTML = `<div class="cbox ${tc2}">
      <div class="tt-big">${a.totalTT}</div>
      <div class="tt-sub">
        <div class="csplit"><span class="ob-tag">OB</span><span class="num">${a.outTT}</span></div>
        <div class="csplit"><span class="mn-tag">MN</span><span class="num">${a.manTT}</span></div>
      </div>${ttNote ? `<div class="tt-note">${ttNote}</div>` : ''}</div>`;

        /* WRAPUP */
        const wc = a.wuBad ? 'cbox-red' : 'cbox-green';
        const _awm = a.avgWu, _awh = Math.floor(_awm / 60), _aws = _awm % 60;
        const avgWuDisp = _awm < 60 ? `${_awm}s` : (_aws > 0 ? `${_awh}m ${_aws}s` : `${_awh}m`);
        const maxWuSec = a.tc * MAX_WU_SEC;
        const maxWuDisp = maxWuSec < 60 ? `${maxWuSec}s` : maxWuSec < 3600 ? `${Math.floor(maxWuSec / 60)}m${maxWuSec % 60 > 0 ? ' ' + maxWuSec % 60 + 's' : ''}` : `${Math.floor(maxWuSec / 3600)}h ${Math.floor(maxWuSec % 3600 / 60)}m`;
        const wuExtraHTML = a.wuBad ? `<div class="wu-extra">+ Extra: <strong>${hmShort(a.wuWaste)}</strong></div>` : '';
        const wuHTML = `<div class="cbox ${wc}"><div class="wu-row1">${a.wrapup}<span class="wu-sep"> · </span>${avgWuDisp} / call</div><div class="wu-row2">Max: ${maxWuDisp} · 10s / call</div>${wuExtraHTML}</div>`;

        /* AUTO IDLE */
        const aiHTML = `<div class="cbox cbox-neutral"><div class="idle-main">${a.autoIdle}</div></div>`;

        /* MANUAL IDLE */
        const mc = a.miBad ? 'cbox-red' : 'cbox-green';
        const miHTML = `<div class="cbox ${mc}"><div class="idle-main">${a.manualIdle}${a.miBad ? ' ⚠' : ''}</div>${a.miBad ? '<div class="brk-sub">Full time = waste</div>' : ''}</div>`;

        /* BREAK */
        const bc = a.brkBad ? 'cbox-red' : 'cbox-green';
        const brkHTML = `<div class="cbox ${bc}">
      <div class="brk-main">${a.breakTime}${a.brkBad ? ' ⚠' : ''}</div>
      ${a.brkBad ? `<div class="brk-sub">+${hmShort(a.brkSec - MAX_BRK_SEC)} over</div>` : ''}</div>`;

        /* WASTE */
        const issues = [];
        if (a.isLate) issues.push({ label: `Late Login: +${a.lateMins}m`, value: hmShort(a.lateWaste) });
        if (a.isEarly) issues.push({ label: `Early Exit: -${a.earlyMins}m`, value: hmShort(a.earlyWaste) });
        if (a.miBad) issues.push({ label: `Manual Idle`, value: hmShort(a.miSec) });
        if (a.wuBad) { const _d = a.avgWu < 60 ? `${a.avgWu}s` : `${Math.floor(a.avgWu / 60)}m ${a.avgWu % 60 > 0 ? a.avgWu % 60 + 's' : ''}`; issues.push({ label: `Wrapup Avg ${_d}/call (>10s)`, value: hmShort(a.wuWaste) }); }
        if (a.ttBad) issues.push({ label: `⚠ Suspicious Talk Time (info only)`, value: hmShort(a.manTTs) });
        if (a.brkBad) issues.push({ label: `Break Exceeded (>1h)`, value: hmShort(a.brkWaste) });

        let iwHTML;
        if (a.wasteSec === 0 && issues.length === 0) {
          iwHTML = `<div class="cbox cbox-green"><div class="iw-zero">✓ No Issues</div></div>`;
        } else {
          const dateLabel = fmtDate(a.date);
          const cpTxt = `📅 *${dateLabel}*\n*Agent: ${a.name} (${a.ext})*\n\n`
            + issues.map((iss, i) => `${i + 1}. ${iss.label} → ${iss.value}`).join('\n')
            + `\n\n*Total Waste: ${hms(a.wasteSec)} (${a.wastePct}% of shift)*`;
          const cpIdx = _cpTexts.length;
          _cpTexts.push(cpTxt);
          const issueList = issues.map(i => `<div class="iw-row"><div class="iw-label">• ${i.label}</div><div class="iw-val">${i.value}</div></div>`).join('');
          iwHTML = `<div class="cbox cbox-red">
        <div class="iw-head">
          <span class="iw-head-txt"><span style="font-size:12px;opacity:.8">${issues.length} Issue${issues.length !== 1 ? 's' : ''} &nbsp;·&nbsp;</span>Total: ${hms(a.wasteSec)} (${a.wastePct}%)</span>
          <button class="wa-btn" onclick="cpI(this,${cpIdx})" title="Copy for WhatsApp">📱</button>
        </div>
        <div class="iw-items">${issueList}</div>
      </div>`;
        }

        const tr = document.createElement('tr');
        tr.innerHTML = `
      <td><span class="sn-num">${a._sn}</span></td>
      <td><div class="ag-name">${a.name}</div>${nameExtra}</td>
      <td>${sessHTML}</td>
      <td>${callsHTML}</td>
      <td>${ttHTML}</td>
      <td>${wuHTML}</td>
      <td>${aiHTML}</td>
      <td>${miHTML}</td>
      <td>${brkHTML}</td>
      <td>${iwHTML}</td>`;
        tbody.appendChild(tr);
      });
    }

    /* ── EXCEL UPLOAD ─────────────────────────────────────────────────────── */
    const COLUMN_MAP = {
      '##': '_sn', '#': '_sn', 'sr no': '_sn', 'sr. no': '_sn', 'sr. no.': '_sn', 'sl no': '_sn', 'sl. no': '_sn', 'sl. no.': '_sn', 'sl.no.': '_sn', 's no': '_sn', 's.no': '_sn', 's.no.': '_sn', 'serial no': '_sn', 'serial no.': '_sn', 'serial number': '_sn', 'sno': '_sn', 'srno': '_sn', 'slno': '_sn', 'no.': '_sn', 'no': '_sn',
      'date': 'date', 'report date': 'date', 'data date': 'date', 'login date': 'date', 'working date': 'date', 'day': 'date', 'रिपोर्ट डेट': 'date', 'तारीख': 'date',
      'name': 'name', 'agent name': 'name', 'agent': 'name', 'agentname': 'name', 'user': 'name', 'username': 'name', 'user name': 'name',
      'ext': 'ext', 'extension': 'ext', 'agent id': 'ext', 'agentid': 'ext', 'agent_id': 'ext', 'id': 'ext', 'agent no': 'ext', 'agentno': 'ext', 'sip': 'ext', 'user ext': 'ext', 'user extension': 'ext',
      'logintime': 'loginTime', 'login time': 'loginTime', 'login': 'loginTime', 'start time': 'loginTime', 'starttime': 'loginTime', 'in time': 'loginTime', 'first login': 'loginTime', 'firstlogin': 'loginTime', 'first login time': 'loginTime',
      'logouttime': 'logoutTime', 'logout time': 'logoutTime', 'logout': 'logoutTime', 'end time': 'logoutTime', 'endtime': 'logoutTime', 'out time': 'logoutTime', 'last logout': 'logoutTime', 'lastlogout': 'logoutTime', 'last logout time': 'logoutTime',
      'logindur': 'loginDur', 'login duration': 'loginDur', 'login dur': 'loginDur', 'duration': 'loginDur', 'session': 'loginDur', 'session duration': 'loginDur', 'total login duration': 'loginDur', 'mode duration': 'loginDur', 'modeduration': 'loginDur', 'login session': 'loginDur', 'total duration': 'loginDur',
      'outcalls': 'outCalls', 'ob calls': 'outCalls', 'outbound calls': 'outCalls', 'out calls': 'outCalls', 'ob': 'outCalls', 'dialed calls': 'outCalls', 'total outbound calls': 'outCalls', 'outbound call': 'outCalls',
      'outtt': 'outTT', 'ob tt': 'outTT', 'outbound tt': 'outTT', 'ob talk time': 'outTT', 'out tt': 'outTT', 'outbound talk time': 'outTT', 'dialed talk time': 'outTT', 'outbound duration': 'outTT', 'ob duration': 'outTT',
      'mancalls': 'manCalls', 'mn calls': 'manCalls', 'mn call': 'manCalls', 'manual calls': 'manCalls', 'mn': 'manCalls', 'inbound calls': 'manCalls', 'ib calls': 'manCalls', 'total manual calls': 'manCalls', 'inbound call': 'manCalls', 'ib call': 'manCalls', 'manual call': 'manCalls', 'Manual Call': 'manCalls', 'Manual Calls': 'manCalls', 'mncalls': 'manCalls', 'manual_call': 'manCalls', 'manual_calls': 'manCalls', 'man calls': 'manCalls', 'man call': 'manCalls',
      'mantt': 'manTT', 'mn tt': 'manTT', 'mntt': 'manTT', 'manual tt': 'manTT', 'manual talk time': 'manTT', 'inbound talk time': 'manTT', 'ib tt': 'manTT', 'ib duration': 'manTT', 'inbound duration': 'manTT', 'manual duration': 'manTT', 'manual call duration': 'manTT', 'Manual Call Duration': 'manTT', 'Manual Duration': 'manTT', 'manual call tt': 'manTT',
      'totaltt': 'totalTT', 'total tt': 'totalTT', 'total talk time': 'totalTT', 'total time': 'totalTT', 'talk time': 'totalTT', 'talktime': 'totalTT', 'att': 'totalTT', 'aht': 'totalTT',
      'autoidle': 'autoIdle', 'auto idle': 'autoIdle', 'system idle': 'autoIdle', 'idle time': 'autoIdle', 'idletime': 'autoIdle', 'idle duration': 'autoIdle', 'auto idle duration': 'autoIdle',
      'manualIdle': 'manualIdle', 'manual idle': 'manualIdle', 'mn idle': 'manualIdle', 'manual idle duration': 'manualIdle',
      'breaktime': 'breakTime', 'break time': 'breakTime', 'break': 'breakTime', 'break duration': 'breakTime', 'total break duration': 'breakTime', 'total break': 'breakTime',
      'wrapup': 'wrapup', 'wrap up': 'wrapup', 'wrap-up': 'wrapup', 'after call work': 'wrapup', 'acw': 'wrapup', 'wrapup duration': 'wrapup', 'wrap up duration': 'wrapup',
      'loginmin': 'loginMin', 'login min': 'loginMin', 'logoutmin': 'logoutMin', 'logout min': 'logoutMin',
      // Additional columns (ignored but mapped to prevent "unrecognized" errors)
      'campaign': '_ignore', 'transfer': '_ignore', 'transfer duration': '_ignore', 'conf': '_ignore', 'conf.': '_ignore', 'conf. duration': '_ignore', 'recall': '_ignore', 'recall duration': '_ignore', 'hold': '_ignore', 'hold duration': '_ignore', 'review': '_ignore', 'review duration': '_ignore', 'sms': '_ignore', 'e-mail': '_ignore', 'in_meeting duration': '_ignore', 'in_disbursal duration': '_ignore', 'in_discussion duration': '_ignore', 'on_other_call duration': '_ignore', 'total calls': '_ignore',
    };
    const REQUIRED_FIELDS = ['name', 'ext', 'loginTime', 'logoutTime', 'loginDur'];

    function parseTimeToHMS(val) {
      if (val === '' || val === null || val === undefined) return '00:00:00';
      if (typeof val === 'number') { const tf = val > 1 ? val % 1 : val; const ts = Math.round(tf * 86400); const h = Math.floor(ts / 3600), m = Math.floor((ts % 3600) / 60), s = ts % 60; return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`; }
      const s = String(val).trim();
      if (/^\d{1,2}:\d{2}:\d{2}$/.test(s)) { const [h, m, sc] = s.split(':'); return `${String(parseInt(h)).padStart(2, '0')}:${m}:${sc}`; }
      if (/^\d{1,2}:\d{2}$/.test(s)) return `${String(parseInt(s.split(':')[0])).padStart(2, '0')}:${s.split(':')[1]}:00`;
      return '00:00:00';
    }
    function parseDisplayTime(val) {
      if (val === '' || val === null || val === undefined) return { display: '—', minutes: 0 };
      if (typeof val === 'number') { const tf = val > 1 ? val % 1 : val; const tm = Math.round(tf * 1440); const h24 = Math.floor(tm / 60) % 24, mn = tm % 60; const ap = h24 >= 12 ? 'PM' : 'AM'; const h12 = h24 % 12 === 0 ? 12 : h24 % 12; return { display: `${String(h12).padStart(2, '0')}:${String(mn).padStart(2, '0')} ${ap}`, minutes: h24 * 60 + mn }; }
      const s = String(val).trim();
      const dtm = s.match(/^\S+\s+(\d{1,2}:\d{2}(?::\d{2})?(?:\s*[AP]M)?)$/i);
      if (dtm) return parseDisplayTime(dtm[1]);
      const m12 = s.match(/^(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM)$/i);
      if (m12) { let h = parseInt(m12[1]), mn = parseInt(m12[2]); const ap = m12[3].toUpperCase(); if (ap === 'AM' && h === 12) h = 0; else if (ap === 'PM' && h !== 12) h += 12; const h12 = h % 12 === 0 ? 12 : h % 12; return { display: `${String(h12).padStart(2, '0')}:${String(mn).padStart(2, '0')} ${ap}`, minutes: h * 60 + mn }; }
      const m24 = s.match(/^(\d{1,2}):(\d{2})(?::\d{2})?$/);
      if (m24) { let h24 = parseInt(m24[1]), mn = parseInt(m24[2]); if (h24 >= 24) h24 = h24 % 24; const ap = h24 >= 12 ? 'PM' : 'AM'; const h12 = h24 % 12 === 0 ? 12 : h24 % 12; return { display: `${String(h12).padStart(2, '0')}:${String(mn).padStart(2, '0')} ${ap}`, minutes: h24 * 60 + mn }; }
      return { display: s, minutes: 0 };
    }
    function parseDate(val) {
      if (!val) return '';
      console.log('[parseDate] input:', typeof val, val);
      if (typeof val === 'number') {
        const ds = Math.floor(val); if (ds < 1) return ''; try { const d = XLSX.SSF.parse_date_code(ds); if (d && d.y > 1900) { const result = `${d.y}-${String(d.m).padStart(2, '0')}-${String(d.d).padStart(2, '0')}`; console.log('[parseDate] number result:', result); return result; } } catch { }
        const jd = new Date(Math.round((ds - 25569) * 86400 * 1000)); if (!isNaN(jd)) { const result = `${jd.getUTCFullYear()}-${String(jd.getUTCMonth() + 1).padStart(2, '0')}-${String(jd.getUTCDate()).padStart(2, '0')}`; console.log('[parseDate] epoch result:', result); return result; } return '';
      }
      const s = String(val).trim();
      if (/^\d{4}-\d{2}-\d{2}$/.test(s)) { console.log('[parseDate] already ISO:', s); return s; }
      // Handle ordinal dates: "20th Feb 2026 09:54:22 AM" or "1st January 2026"
      const MONTHS = { jan: 1, feb: 2, mar: 3, apr: 4, may: 5, jun: 6, jul: 7, aug: 8, sep: 9, oct: 10, nov: 11, dec: 12, january: 1, february: 2, march: 3, april: 4, june: 6, july: 7, august: 8, september: 9, october: 10, november: 11, december: 12 };
      const ordMatch = s.match(/^(\d{1,2})(?:st|nd|rd|th)\s+([a-zA-Z]+)\s+(\d{4})/i);
      if (ordMatch) { const mon = MONTHS[ordMatch[2].toLowerCase()]; if (mon) { const result = `${ordMatch[3]}-${String(mon).padStart(2, '0')}-${String(parseInt(ordMatch[1])).padStart(2, '0')}`; console.log('[parseDate] ordinal date result:', result); return result; } }
      if (s.includes(' ') || s.includes('T')) { const dp = s.split(/[\sT]/)[0]; if (/\d/.test(dp) && dp !== s) { const inner = parseDate(dp); if (inner && /^\d{4}-\d{2}-\d{2}$/.test(inner)) { console.log('[parseDate] datetime split result:', inner); return inner; } } }
      const m = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
      if (m) { const a = parseInt(m[1]), b = parseInt(m[2]); console.log('[parseDate] DD/MM match, a=', a, 'b=', b); if (b > 12) { const result = `${m[3]}-${String(a).padStart(2, '0')}-${String(b).padStart(2, '0')}`; console.log('[parseDate] MM/DD result:', result); return result; } const result = `${m[3]}-${String(b).padStart(2, '0')}-${String(a).padStart(2, '0')}`; console.log('[parseDate] DD/MM result:', result); return result; }
      const mt1 = s.match(/^(\d{1,2})[\s\-\/]([a-zA-Z]+)[\s\-\/,]?\s*(\d{2,4})$/);
      if (mt1) { const mon = MONTHS[mt1[2].toLowerCase()]; if (mon) { const yr = mt1[3].length === 2 ? 2000 + parseInt(mt1[3]) : parseInt(mt1[3]); const result = `${yr}-${String(mon).padStart(2, '0')}-${String(parseInt(mt1[1])).padStart(2, '0')}`; console.log('[parseDate] text month result:', result); return result; } }
      const mt2 = s.match(/^([a-zA-Z]+)[\s\-\/,]?\s*(\d{1,2}),?\s*(\d{2,4})$/);
      if (mt2) { const mon = MONTHS[mt2[1].toLowerCase()]; if (mon) { const yr = mt2[3].length === 2 ? 2000 + parseInt(mt2[3]) : parseInt(mt2[3]); const result = `${yr}-${String(mon).padStart(2, '0')}-${String(parseInt(mt2[2])).padStart(2, '0')}`; console.log('[parseDate] month-day result:', result); return result; } }
      const m2 = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2})$/);
      if (m2) { const yr = 2000 + parseInt(m2[3]); const result = `${yr}-${String(parseInt(m2[2])).padStart(2, '0')}-${String(parseInt(m2[1])).padStart(2, '0')}`; console.log('[parseDate] 2-digit year result:', result); return result; }
      console.log('[parseDate] no match, returning raw:', s);
      return s;
    }
    function sanitizeV(val) { if (val === null || val === undefined) return ''; return String(val).replace(/<[^>]*>/g, '').trim(); }

    function parseExcelFile(file) {
      return new Promise((resolve, reject) => {
        if (file.size > 10 * 1024 * 1024) { reject(new Error('File too large. Max 10MB.')); return; }
        const fx = file.name.split('.').pop().toLowerCase();
        if (!['xlsx', 'xls'].includes(fx)) { reject(new Error('Only .xlsx / .xls files accepted.')); return; }
        const reader = new FileReader();
        reader.onload = e => {
          try {
            const wb = XLSX.read(e.target.result, { type: 'array', cellDates: false });
            const sheet = wb.Sheets[wb.SheetNames[0]];
            const rawRows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '' });
            if (rawRows.length < 2) { reject(new Error('File is empty or has no data rows.')); return; }
            const headerRow = rawRows[0].map(h => String(h).trim());
            const fieldMap = {}; const unmapped = []; const mappedFieldSet = new Set();
            console.log('[parseExcelFile] raw headers:', headerRow);

            headerRow.forEach((h, i) => {
              const key = h.toLowerCase();
              const keyNoSpace = key.replace(/\s+/g, '');
              const cleanKey = key.replace(/[^a-z0-9]/g, '');
              let f = COLUMN_MAP[key] || COLUMN_MAP[h] || COLUMN_MAP[keyNoSpace] || COLUMN_MAP[cleanKey];

              if (!f && (cleanKey.includes('manual') || cleanKey.includes('inbound') || cleanKey.includes('ib')) && (cleanKey.includes('call') || cleanKey.includes('mn'))) {
                f = cleanKey.includes('duration') || cleanKey.includes('time') || cleanKey.includes('tt') ? 'manTT' : 'manCalls';
              }
              if (!f && (cleanKey.includes('manual') || cleanKey.includes('inbound') || cleanKey.includes('ib')) && (cleanKey.includes('duration') || cleanKey.includes('time'))) f = 'manTT';

              if (f) {
                if (f === '_ignore') {
                  fieldMap[i] = f;
                } else if (!mappedFieldSet.has(f)) {
                  fieldMap[i] = f;
                  mappedFieldSet.add(f);
                }
              } else if (h !== '') {
                unmapped.push(h);
              }
            });
            // Debug: show exactly what each column mapped to
            const fieldMapDebug = {};
            Object.entries(fieldMap).forEach(([ci, fn]) => { if (fn !== '_ignore') fieldMapDebug[headerRow[parseInt(ci)]] = fn; });
            console.log('[parseExcelFile] fieldMap:', fieldMapDebug);
            console.log('[parseExcelFile] unmapped headers:', unmapped);
            const mappedFields = Object.values(fieldMap);
            const missing = REQUIRED_FIELDS.filter(f => !mappedFields.includes(f));
            if (missing.length > 0) {
              const hints = {
                loginTime: 'First Login, Login Time, Login, Start Time',
                logoutTime: 'Last Logout, Logout Time, Logout, End Time',
                loginDur: 'Login Duration, Session, Duration, Mode Duration',
                name: 'Name, Agent Name, Agent, User',
                ext: 'Ext, Extension, Agent ID, SIP, User Ext'
              };
              const help = missing.map(f => `${f} (try: ${hints[f] || f})`).join(', ');
              reject(new Error('Missing required columns: ' + help + '\n\nUnrecognized headers in your Excel:\n' + (unmapped.length ? unmapped.join(', ') : 'none') + '\n\nPlease rename Excel columns to match expected names.'));
              return;
            }
            const agents = []; const rowErrors = []; const hasDateCol = mappedFields.includes('date');
            console.log('[PARSE] hasDateCol:', hasDateCol);
            console.log('[PARSE] mappedFields:', mappedFields);
            let debugFirstRow = true;
            rawRows.slice(1).forEach((row, ri) => {
              if (row.every(c => c === '' || c === null || c === undefined)) return;
              const rec = {};
              Object.entries(fieldMap).forEach(([ci, fn]) => { rec[fn] = row[parseInt(ci)]; });
              const isFirstDataRow = debugFirstRow;
              if (debugFirstRow) {
                console.log('[PARSE] First row rec.date:', typeof rec.date, rec.date);
                console.log('[PARSE] First row rec.loginTime:', typeof rec.loginTime, rec.loginTime);
                debugFirstRow = false;
              }
              const loginP = parseDisplayTime(rec.loginTime);
              const logoutP = parseDisplayTime(rec.logoutTime);
              let dateVal = hasDateCol ? parseDate(rec.date) : '';
              if (isFirstDataRow) {
                console.log('[PARSE] After first parseDate, dateVal:', dateVal);
              }
              if (dateVal && !/^\d{4}-\d{2}-\d{2}$/.test(dateVal)) dateVal = '';
              if (!dateVal && rec.loginTime) {
                if (typeof rec.loginTime === 'number' && rec.loginTime > 1) dateVal = parseDate(Math.floor(rec.loginTime));
                else if (typeof rec.loginTime === 'string') dateVal = parseDate(rec.loginTime);
                if (isFirstDataRow) {
                  console.log('[PARSE] After loginTime fallback, dateVal:', dateVal);
                }
                if (dateVal && !/^\d{4}-\d{2}-\d{2}$/.test(dateVal)) dateVal = '';
              }
              if (!dateVal) { const t = new Date(); dateVal = `${t.getFullYear()}-${String(t.getMonth() + 1).padStart(2, '0')}-${String(t.getDate()).padStart(2, '0')}`; }
              if (isFirstDataRow) {
                console.log('[PARSE] Final dateVal:', dateVal);
              }
              const outTTstr = parseTimeToHMS(rec.outTT || 0), manTTstr = parseTimeToHMS(rec.manTT || 0);
              let totalTTstr;
              if (rec.totalTT !== undefined && rec.totalTT !== '') totalTTstr = parseTimeToHMS(rec.totalTT);
              else { const ss = toSec(outTTstr) + toSec(manTTstr); totalTTstr = hms(ss); }
              const nameVal = sanitizeV(rec.name) || sanitizeV(rec.ext);
              const extVal = sanitizeV(rec.ext) || sanitizeV(rec.name);
              const isHeaderRepeat = /^\s*sl\.?\s*no\.?\s*$/i.test(nameVal) || /^\s*sr\.?\s*no\.?\s*$/i.test(nameVal);
              const isBlankRow = !nameVal && !extVal;
              const isTotalRow = /^(grand\s*)?totals?$/i.test(nameVal) || (/total/i.test(nameVal) && (extVal === '' || extVal === nameVal));
              if (isHeaderRepeat || isBlankRow || isTotalRow) return;
              const excelSN = rec._sn !== undefined && rec._sn !== '' ? String(rec._sn).trim() : null;
              const errs = [];
              if (!nameVal) errs.push('name empty');
              if (!extVal) errs.push('ext empty');
              if (errs.length > 0) { rowErrors.push(`Row ${ri + 2}: ${errs.join(', ')}`); return; }
              agents.push({ date: dateVal, name: nameVal, ext: extVal, loginTime: loginP.display, logoutTime: logoutP.display, loginDur: parseTimeToHMS(rec.loginDur || 0), outCalls: parseInt(rec.outCalls) || 0, outTT: outTTstr, manCalls: parseInt(rec.manCalls) || 0, manTT: manTTstr, totalTT: totalTTstr, autoIdle: parseTimeToHMS(rec.autoIdle || 0), manualIdle: parseTimeToHMS(rec.manualIdle || 0), breakTime: parseTimeToHMS(rec.breakTime || 0), wrapup: parseTimeToHMS(rec.wrapup || 0), loginMin: rec.loginMin !== undefined && rec.loginMin !== '' ? parseInt(rec.loginMin) : loginP.minutes, logoutMin: rec.logoutMin !== undefined && rec.logoutMin !== '' ? parseInt(rec.logoutMin) : logoutP.minutes, _sn: excelSN });
            });
            // DEBUG: Show parsed manCalls values via alert so user can see immediately 
            const mnDebug = agents.slice(0, 5).map(a => `${a.name}: MN=${a.manCalls} MN-TT=${a.manTT} OB=${a.outCalls}`).join('\n');
            console.log('[parseExcelFile] PARSED AGENTS (first 5):', mnDebug);
            alert('PARSED DATA (first 5 agents):\n\n' + mnDebug + '\n\nIf MN shows 0 here, the Excel column is not being read correctly.');
            resolve({ agents, rowErrors, totalRows: rawRows.length - 1, unmapped });
          } catch (err) { reject(new Error('Parse error: ' + err.message)); }
        };
        reader.onerror = () => reject(new Error('Failed to read file.'));
        reader.readAsArrayBuffer(file);
      });
    }

    // Upload modal state
    let _uplParsed = null;
    function openUpload() { document.getElementById('uplModal').classList.add('show'); }
    function closeUpload() { document.getElementById('uplModal').classList.remove('show'); _uplParsed = null; showUplIdle(); }
    function closeUplOutside(e) { if (e.target === document.getElementById('uplModal')) closeUpload(); }
    function showUplIdle() { document.getElementById('dropzone').style.display = ''; document.getElementById('uplStatus').style.display = 'none'; document.getElementById('uplActions').style.display = 'none'; }
    function dzOver(e) { e.preventDefault(); document.getElementById('dropzone').classList.add('drag'); }
    function dzLeave() { document.getElementById('dropzone').classList.remove('drag'); }
    function dzDrop(e) { e.preventDefault(); dzLeave(); const f = e.dataTransfer.files[0]; if (f) processUpload(f); }
    function handleFileInput(inp) { if (inp.files[0]) processUpload(inp.files[0]); inp.value = ''; }

    async function processUpload(file) {
      document.getElementById('dropzone').style.display = 'none';
      const statusEl = document.getElementById('uplStatus');
      const actionsEl = document.getElementById('uplActions');
      statusEl.style.display = '';
      actionsEl.style.display = 'none';
      statusEl.className = 'upl-status parsing';
      statusEl.textContent = '⏳ Parsing ' + file.name + ' ...';
      try {
        const result = await parseExcelFile(file);
        _uplParsed = result;
        // Debug: show first agent's date
        const firstDate = result.agents.length > 0 ? result.agents[0].date : 'none';
        console.log('First agent date:', firstDate);
        console.log('All unique dates:', JSON.stringify([...new Set(result.agents.map(a => a.date))]));
        statusEl.className = 'upl-status success';
        statusEl.textContent = `✅ Parsed ${result.agents.length} agent records from ${result.totalRows} rows.`
          + (result.rowErrors.length ? `\n⚠ ${result.rowErrors.length} rows skipped (missing name/ext).` : '')
          + `\n\n[DEBUG] First agent date: ${firstDate}`;
        actionsEl.style.display = 'flex';
        actionsEl.innerHTML = `<button class="upl-btn upl-btn-cancel" onclick="closeUpload()">Cancel</button><button class="upl-btn upl-btn-confirm" onclick="loadParsedData()">✅ Load Data</button>`;
      } catch (err) {
        statusEl.className = 'upl-status error';
        statusEl.textContent = '❌ ' + err.message;
        actionsEl.style.display = 'flex';
        actionsEl.innerHTML = `<button class="upl-btn upl-btn-clear" onclick="showUplIdle();document.getElementById('dropzone').style.display='';">Try Again</button><button class="upl-btn upl-btn-cancel" onclick="closeUpload()">Close</button>`;
        _uplParsed = null;
      }
    }

    function loadParsedData() {
      if (!_uplParsed || !_uplParsed.agents.length) return;
      ALL_AGENTS.length = 0;
      _uplParsed.agents.forEach(a => ALL_AGENTS.push(a));
      console.log('[loadParsedData] Loaded agents count:', ALL_AGENTS.length);
      console.log('[loadParsedData] First 3 agent dates:', ALL_AGENTS.slice(0, 3).map(a => ({ name: a.name, date: a.date })));
      console.log('[loadParsedData] All unique dates:', [...new Set(ALL_AGENTS.map(a => a.date))].sort());
      // Rebuild serial numbers
      Object.keys(_agentSN).forEach(k => delete _agentSN[k]);
      let n = 1; ALL_AGENTS.forEach(a => { if (_agentSN[a.ext] === undefined) _agentSN[a.ext] = n++; });
      // Clear filter selects
      ['dateFrom', 'dateTo'].forEach(id => { const s = document.getElementById(id); while (s.options.length) s.remove(0); });
      const as = document.getElementById('agentSelect'); while (as.options.length > 1) as.remove(1);
      selectedAgent = ''; filterFrom = ''; filterTo = '';
      // Update upload button
      document.getElementById('uploadBtn').textContent = '📊 Excel Loaded ✓';
      document.getElementById('uploadBtn').className = 'upload-btn loaded';
      closeUpload();
      initFilters();
    }

    function cpI(btn, idx) {
      const txt = _cpTexts[idx] || '';
      navigator.clipboard.writeText(txt).then(() => {
        const orig = btn.textContent;
        btn.textContent = '✓';
        btn.style.background = '#155724';
        setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 1800);
      });
    }
    function sortBy(k) { if (sortKey === k) sortDir *= -1; else { sortKey = k; sortDir = -1; } render(); }
    function toggleRules() {
      document.getElementById('rulesModal').classList.toggle('show');
      if (document.getElementById('rulesModal').classList.contains('show')) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    }
    function closeModalOutside(e) {
      if (e.target === document.getElementById('rulesModal')) toggleRules();
    }
    initFilters();
  </script>
</body>

</html>